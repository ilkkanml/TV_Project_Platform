generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  RESELLER
  ADMIN
}

enum ClientPlatform {
  ANDROID_TV
  FIRE_TV
  ANDROID_MOBILE
  IOS
  APPLE_TV
  SAMSUNG_TIZEN
  LG_WEBOS
  WEB_PLAYER
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  EXPIRED
  SUSPENDED
}

enum DeviceStatus {
  PENDING
  ACTIVE
  DISABLED
  REVOKED
  BLOCKED
}

enum ActivationSessionStatus {
  PENDING
  APPROVED
  EXPIRED
  CONSUMED
  REJECTED
}

enum LicenseState {
  FREE_LAUNCH_ACTIVE
  ACTIVE
  TRIALING
  EXPIRED
  SUSPENDED
  DEVICE_REVOKED
  BLOCKED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  devices             Device[]
  subscriptions       Subscription[]
  licenseGrants       LicenseGrant[]
  activationSessions  ActivationSession[]
  transferSessions    PlaylistTransferSession[]
  reseller            ResellerProfile?
}

model DeviceAccessRecord {
  id                 String   @id @default(cuid())
  deviceId           String   @unique
  platformDeviceHash String?
  activationKeyHash  String
  activationKeyHint  String?
  platform           String
  appVersion         String
  status             String   @default("active")
  licenseState       String   @default("free_launch_active")
  freeLaunch         Boolean  @default(true)
  paymentRequired    Boolean  @default(false)
  firstSeenAt        DateTime @default(now())
  lastSeenAt         DateTime @default(now())
  lastRecoveredAt    DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  ownerNote          String?

  @@index([platformDeviceHash])
  @@index([status])
  @@index([licenseState])
  @@index([lastSeenAt])
  @@index([platform, appVersion])
  @@index([freeLaunch])
  @@index([paymentRequired])
  @@index([createdAt])
}

model Device {
  id          String         @id @default(cuid())
  userId      String
  name        String
  deviceKey   String         @unique
  platform    ClientPlatform @default(ANDROID_TV)
  appVersion  String?
  status      DeviceStatus   @default(PENDING)
  activatedAt DateTime?
  revokedAt   DateTime?
  lastSeenAt  DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user               User                      @relation(fields: [userId], references: [id])
  licenseGrants      LicenseGrant[]
  activationSessions ActivationSession[]
  transferSessions   PlaylistTransferSession[]

  @@index([userId])
  @@index([platform, status])
}

model ActivationSession {
  id          String                  @id @default(cuid())
  code        String                  @unique
  status      ActivationSessionStatus @default(PENDING)
  platform    ClientPlatform          @default(ANDROID_TV)
  deviceName  String?
  deviceKey   String?
  appVersion  String?
  userId      String?
  deviceId    String?
  expiresAt   DateTime
  approvedAt  DateTime?
  consumedAt  DateTime?
  rejectedAt  DateTime?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  user   User?   @relation(fields: [userId], references: [id])
  device Device? @relation(fields: [deviceId], references: [id])

  @@index([code, status])
  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt])
}

model LicenseGrant {
  id              String       @id @default(cuid())
  userId          String
  deviceId        String?
  state           LicenseState @default(FREE_LAUNCH_ACTIVE)
  freeLaunch      Boolean      @default(true)
  validFrom       DateTime     @default(now())
  validUntil      DateTime?
  lastCheckedAt   DateTime?
  message         String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  user   User    @relation(fields: [userId], references: [id])
  device Device? @relation(fields: [deviceId], references: [id])

  @@index([userId, state])
  @@index([deviceId, state])
  @@index([freeLaunch])
}

model Subscription {
  id        String             @id @default(cuid())
  userId    String
  status    SubscriptionStatus @default(TRIALING)
  startsAt  DateTime
  endsAt    DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId, status])
}

model ResellerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  creditBalance Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user   User                @relation(fields: [userId], references: [id])
  ledger CreditLedgerEntry[]
}

model CreditLedgerEntry {
  id          String   @id @default(cuid())
  resellerId  String
  amount      Int
  reason      String
  referenceId String?
  createdAt   DateTime @default(now())

  reseller ResellerProfile @relation(fields: [resellerId], references: [id])

  @@index([resellerId])
}

model RemoteConfig {
  id        String          @id @default(cuid())
  scope     String          @default("global")
  key       String
  platform  ClientPlatform?
  valueJson Json
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@unique([scope, key, platform])
  @@index([platform, enabled])
}

model AppVersion {
  id                  String         @id @default(cuid())
  platform            ClientPlatform
  version             String
  channel             String         @default("stable")
  currentRecommended  Boolean        @default(false)
  minimumSupported    String?
  updateUrl           String?
  forceUpdate         Boolean        @default(false)
  enabled             Boolean        @default(true)
  releaseNotes        String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@unique([platform, version, channel])
  @@index([platform, currentRecommended])
  @@index([platform, enabled])
}

model PlaylistTransferSession {
  id                String    @id @default(cuid())
  userId            String
  deviceId          String
  encryptedPayload  String
  payloadVersion    String    @default("v1")
  expiresAt         DateTime
  consumedAt        DateTime?
  createdAt         DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id])
  device Device @relation(fields: [deviceId], references: [id])

  @@index([userId, deviceId])
  @@index([expiresAt])
  @@index([consumedAt])
}

model PaymentEvent {
  id              String   @id @default(cuid())
  provider        String
  providerEventId String   @unique
  eventType       String
  payloadJson     Json
  createdAt       DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorType  String?
  actorId    String?
  action     String
  target     String?
  targetType String?
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorType, actorId])
  @@index([actorId])
  @@index([action])
  @@index([targetType, targetId])
  @@index([createdAt])
}
