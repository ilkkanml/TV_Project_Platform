# TV_Project_Platform API environment template
# Copy this file to .env for local development.
# Never commit real secrets.

APP_ENV=development
API_PORT=4000
PORT=4000

# Local PostgreSQL example. Replace values locally only.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tv_project_platform_dev?schema=public"

# CORS origin for local web app.
CORS_ORIGIN="http://localhost:3000"

# Logging level for local development.
LOG_LEVEL=debug

# EA0 flags. Runtime values should also exist in RemoteConfig seed.
EA0_FREE_LAUNCH_ENABLED=true
EA0_DEVICE_BOOTSTRAP_ENABLED=true
EA0_LICENSE_CHECK_ENABLED=true

# Placeholder only. Actual hashing configuration/secrets must be set outside repo.
ACTIVATION_KEY_HASH_CONFIG="development-placeholder-do-not-use-in-production"
