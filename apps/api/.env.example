# TV_Project_Platform API environment template
# Copy this file to .env for local development or cPanel/hosting setup.
# Never commit real secrets.

APP_ENV=development
API_PORT=4000
PORT=4000

# MySQL / MariaDB example for local Docker.
DATABASE_URL="mysql://tv_platform:tv_platform_password@localhost:3306/tv_project_platform"

# cPanel MySQL format example. Replace locally only:
# DATABASE_URL="mysql://CPANEL_DB_USER:CPANEL_DB_PASSWORD@CPANEL_DB_HOST:3306/CPANEL_DB_NAME"

# CORS origin for local web app.
CORS_ORIGIN="http://localhost:3000"

# Logging level for local development.
LOG_LEVEL=debug

# EA0 flags. Runtime values should also exist in RemoteConfig seed.
EA0_FREE_LAUNCH_ENABLED=true
EA0_DEVICE_BOOTSTRAP_ENABLED=true
EA0_LICENSE_CHECK_ENABLED=true

# Placeholder only. Actual hashing configuration/secrets must be set outside repo.
ACTIVATION_KEY_HASH_CONFIG="development-placeholder-do-not-use-in-production"
