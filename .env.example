NODE_ENV=development

APP_NAME="TV Project Platform"
APP_WEB_URL="http://localhost:3000"
APP_API_URL="http://localhost:4000"
API_PORT=4000
CORS_ORIGIN="http://localhost:3000"

# MySQL / MariaDB-compatible local Docker database.
DATABASE_URL="mysql://tv_platform:tv_platform_password@localhost:3306/tv_project_platform"
REDIS_URL="redis://localhost:6379"

JWT_ACCESS_SECRET="local_placeholder"
JWT_REFRESH_SECRET="local_placeholder"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

PASSWORD_HASH_ROUNDS=12

PAYMENT_PROVIDER="manual"
PAYMENT_WEBHOOK_SECRET="local_placeholder"

TEMPORARY_TRANSFER_ENCRYPTION_KEY="local_placeholder"
TEMPORARY_TRANSFER_EXPIRES_IN="15m"

ADMIN_SEED_EMAIL="admin@tvplatform.local"
ADMIN_SEED_PASSWORD="local_placeholder"
