NODE_ENV=development
APP_NAME=TV Project Platform
APP_ENV=local
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

DATABASE_URL=postgresql://tv_platform:tv_platform_dev_password@localhost:5432/tv_platform_dev?schema=public
REDIS_URL=redis://localhost:6379

JWT_ACCESS_SECRET=replace-with-local-placeholder-only
JWT_REFRESH_SECRET=replace-with-local-placeholder-only
ENCRYPTION_KEY=replace-with-32-byte-local-placeholder

PAYMENT_PROVIDER=placeholder
PAYMENT_WEBHOOK_SECRET=replace-with-placeholder-only

MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=no-reply@example.test

CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

REMOTE_CONFIG_CACHE_SECONDS=60
APP_VERSION_CHECK_ENABLED=true
PLAYLIST_TRANSFER_BRIDGE_ENABLED=true
