{
  "name": "tv-project-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Licensed IPTV Player Platform - Web, API, Admin, Reseller and Customer management system.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.11.0 <23",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present run dev",
    "dev:web": "pnpm --filter @tv-platform/web run dev",
    "dev:api": "pnpm --filter @tv-platform/api run dev",
    "build": "pnpm -r --if-present run build",
    "start": "pnpm -r --if-present run start",
    "lint": "pnpm -r --if-present run lint",
    "test": "pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yml,yaml}\"",
    "db:generate": "pnpm --filter @tv-platform/api exec prisma generate",
    "db:migrate": "pnpm --filter @tv-platform/api exec prisma migrate dev",
    "db:studio": "pnpm --filter @tv-platform/api exec prisma studio",
    "infra:up": "docker compose up -d",
    "infra:up:tools": "docker compose --profile tools up -d",
    "infra:down": "docker compose down",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prettier": "^3.4.2",
    "prisma": "^6.1.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
